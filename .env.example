NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/tract-app2
JWT_ACCESS_SECRET=<generate_strong_secret_min_32_chars>
JWT_REFRESH_SECRET=<generate_strong_secret_min_32_chars>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
# Local: default broker. Render/Fly/Vercel: set a cloud URL (Upstash, Redis Cloud, etc.) — rediss:// for TLS.
REDIS_URL=redis://localhost:6379
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=<your_twilio_auth_token>
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=<your_gmail>@gmail.com
MAIL_PASS=<16_char_google_app_password>
MAIL_FROM=TRACT <noreply@yourdomain.com>
# Production: verify on boot is off unless MAIL_VERIFY_ON_START=true (Render often blocks SMTP to Gmail).
MAIL_VERIFY_ON_START=
THROTTLE_TTL=60
THROTTLE_LIMIT=100
TEST_BYPASS_OTP=false
TEST_OTP_CODE=123456
TEST_PHONES=
TEST_EMAILS=
# Jumio KYC (amer-1 defaults; override URLs if your tenant is in another region)
JUMIO_API_KEY=
JUMIO_API_SECRET=
# Optional: public base URL Jumio should call back to (same idea as tract-app1 hardcoded Render URL)
JUMIO_CALLBACK_URL=
# Default workflow key from tract-app1 reference (ID + face)
JUMIO_WORKFLOW_KEY=10547
# JUMIO_OAUTH_TOKEN_URL=https://auth.amer-1.jumio.ai/oauth2/token
# JUMIO_ACCOUNTS_URL=https://account.amer-1.jumio.ai/api/v1/accounts
