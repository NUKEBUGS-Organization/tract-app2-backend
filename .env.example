NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/tract-app2
JWT_ACCESS_SECRET=<generate_strong_secret_min_32_chars>
JWT_REFRESH_SECRET=<generate_strong_secret_min_32_chars>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Comma-separated list (no single header with multiple origins — each request echoes one match)
CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=http://localhost:5173,https://tract-app2-frontend.vercel.app
# Local: default broker. Render/Fly/Vercel: set a cloud URL (Upstash, Redis Cloud, etc.) — rediss:// for TLS.
REDIS_URL=redis://localhost:6379
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=<your_twilio_auth_token>
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=TRACT <onboarding@resend.dev>
THROTTLE_TTL=60
THROTTLE_LIMIT=100
TEST_BYPASS_OTP=false
TEST_OTP_CODE=123456
TEST_PHONES=
TEST_EMAILS=

# SPA origin (no trailing slash).
FRONTEND_URL=http://localhost:5173

# Jumio KYC (same integration shape as tract-app1-backend: OAuth → POST /accounts → sdk.token for Web SDK)
JUMIO_API_KEY=
JUMIO_API_SECRET=
#
# callbackUrl sent to Jumio — prefer explicit HTTPS URL (ngrok / prod API host).
# tract-app1 uses the deployed API origin only (example: https://tract-app1-backend.onrender.com).
# You may instead point at your webhook route if your Jumio setup expects it, e.g.:
#   https://YOUR-HOST/api/v1/auth/kyc/webhook
#
# Local dev: expose API over HTTPS (ngrok/cloudflared) and set:
# JUMIO_CALLBACK_URL=https://YOUR-SUBDOMAIN.ngrok-free.app
#
API_PUBLIC_URL=http://127.0.0.1:3001
JUMIO_WORKFLOW_KEY=10547
